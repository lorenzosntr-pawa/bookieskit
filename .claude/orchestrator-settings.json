{
  "permissions": {
    "allow": [
      "Bash(.venv/Scripts/python.exe -m bookieskit.orchestration:*)",
      "Bash(.venv/Scripts/python.exe -m bookieskit.devtools:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh label:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git push --set-upstream origin feat/*)",
      "Bash(git push origin feat/*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent"
    ],
    "deny": [
      "Bash(gh pr merge:*)",
      "Bash(git push origin main:*)",
      "Bash(git push:* main)"
    ]
  }
}
